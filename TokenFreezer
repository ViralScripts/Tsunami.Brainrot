--------------------------------------------------
-- STACKING TOAST SYSTEM
--------------------------------------------------

local activeToasts = {}

local function updateToastPositions()
    for i,toast in ipairs(activeToasts) do
        TweenService:Create(
            toast,
            TweenInfo.new(0.25),
            {Position = UDim2.new(1,-280,1,-70 - ((i-1)*60))}
        ):Play()
    end
end

local function showToast(text)

    local toast = Instance.new("Frame")
    toast.Size = UDim2.fromOffset(260,50)
    toast.Position = UDim2.new(1,300,1,-70)
    toast.BackgroundColor3 = Color3.fromRGB(35,35,35)
    toast.BorderSizePixel = 0
    toast.Parent = screenGui

    Instance.new("UICorner", toast).CornerRadius = UDim.new(0,12)

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1,-15,1,0)
    label.Position = UDim2.new(0,10,0,0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.Font = Enum.Font.GothamBold
    label.TextSize = 14
    label.TextColor3 = Color3.new(1,1,1)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = toast

    table.insert(activeToasts,1,toast)
    updateToastPositions()

    -- Slide in
    TweenService:Create(toast,TweenInfo.new(0.35,Enum.EasingStyle.Quad),{
        Position = UDim2.new(1,-280,toast.Position.Y.Scale,toast.Position.Y.Offset)
    }):Play()

    task.delay(3,function()
        for i,v in ipairs(activeToasts) do
            if v == toast then
                table.remove(activeToasts,i)
                break
            end
        end
        updateToastPositions()

        TweenService:Create(toast,TweenInfo.new(0.3),{
            Position = UDim2.new(1,300,toast.Position.Y.Scale,toast.Position.Y.Offset)
        }):Play()

        task.wait(0.3)
        toast:Destroy()
    end)
end

--------------------------------------------------
-- FREEZE LOGIC + GLOW PULSE
--------------------------------------------------

local freezeEnabled = false
local connection
local glowTween

local function startGlow()
    stroke.Transparency = 0
    stroke.Color = Color3.fromRGB(60,255,120)

    glowTween = TweenService:Create(
        stroke,
        TweenInfo.new(1,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut,-1,true),
        {Thickness = 4}
    )
    glowTween:Play()
end

local function stopGlow()
    if glowTween then glowTween:Cancel() end
    stroke.Transparency = 1
    stroke.Thickness = 2
end

local function enableFreeze()
    if connection then connection:Disconnect() end

    valueLabel.Text = CUSTOM_NUMBER

    connection = valueLabel:GetPropertyChangedSignal("Text"):Connect(function()
        if freezeEnabled then
            valueLabel.Text = CUSTOM_NUMBER
        end
    end)

    toggleButton.BackgroundColor3 = Color3.fromRGB(60,200,100)
    startGlow()
    showToast("Token Successfully Frozen")
end

local function disableFreeze()
    if connection then connection:Disconnect() end
    toggleButton.BackgroundColor3 = Color3.fromRGB(200,60,60)
    stopGlow()
    showToast("Token Unfrozen")
end

toggleButton.MouseButton1Click:Connect(function()
    freezeEnabled = not freezeEnabled
    if freezeEnabled then
        enableFreeze()
    else
        disableFreeze()
    end
end)
