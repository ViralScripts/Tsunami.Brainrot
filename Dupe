-- UPDATE COUNT
local function updateCount()
	countLabel.Text = "x" .. duplicateCount
end

minus.MouseButton1Click:Connect(function()
	duplicateCount = math.max(MIN_COUNT, duplicateCount - 1)
	updateCount()
end)

plus.MouseButton1Click:Connect(function()
	duplicateCount = math.min(MAX_COUNT, duplicateCount + 1)
	updateCount()
end)

