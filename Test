--// Notification (5x)
local function notify(text)
	for i = 1, 5 do
		pcall(function()
			StarterGui:SetCore("SendNotification", {
				Title = "Trade Notification";
				Text = text;
				Duration = 3;
			})
		end)
		task.wait(0.15)
	end
end

freezeBtn.MouseButton1Click:Connect(function()
	notify("Trade Frozen Successfully❄️")
end)

forceBtn.MouseButton1Click:Connect(function()
	notify("Force Accepted Successfully✅")
end)

--// Player Search
local function updatePlayer(searchText)
	if searchText == "" then
		avatar.Image = ""
		playerName.Visible = false
		return
	end

	for _, plr in pairs(Players:GetPlayers()) do
		if string.find(string.lower(plr.Name), string.lower(searchText)) then
			local content = Players:GetUserThumbnailAsync(
				plr.UserId,
				Enum.ThumbnailType.HeadShot,
				Enum.ThumbnailSize.Size100x100
			)
			avatar.Image = content
			playerName.Text = plr.Name
			playerName.Visible = true
			return
		end
	end

	avatar.Image = ""
	playerName.Visible = false
end

searchBox:GetPropertyChangedSignal("Text"):Connect(function()
	updatePlayer(searchBox.Text)
end)

--// Draggable
local dragging, dragInput, dragStart, startPos

main.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = main.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

main.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement then
		dragInput = input
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if input == dragInput and dragging then
		local delta = input.Position - dragStart
		main.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)
